{
  "name": "iptv-player",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n proxy,vite \"node cors-proxy.mjs\" \"vite\"",
    "home": "concurrently -n proxy,vite \"node cors-proxy.mjs\" \"vite --mode home\"",
    "cors-proxy": "node cors-proxy.mjs",
    "tv": "cd ..\\tv && npm run dev",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shaka-player": "^5.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "agentation": "^3.0.2",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  }
}
